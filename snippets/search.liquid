{%- doc -%}
  Renders the search action button.

  @param {string} [style] - The style of the search action.
  @param {string} [class] - Additional classes for the search action.

  @example
  {% render 'search', style: 'default', class: 'custom-class' %}
{%- enddoc -%}

{% unless style == 'none' %}
  <div class="search-action{% if class != blank %} {{ class | strip }}{% endif %}">
    {% render 'predictive-search',
      input_id: 'header-search-input',
      search_test_id: 'search-component--header',
      products_test_id: 'products-list-default--header'
    %}
  </div>
{% endunless %}

{% stylesheet %}
  .search-action {
    --search-border-radius: var(--style-border-radius-inputs);
    --search-border-width: var(--style-border-width-inputs);

    display: flex;
    align-items: center;
    height: 44px; /* Prevent stretching full into the header height */
  }

  /* Desktop: search fills all available center space between logo and actions */
  @media screen and (min-width: 750px) {
    .header__column--center .search-action {
      width: 100%;
      flex: 1;
      min-width: 0;
    }

    .header__column--center .search-action predictive-search,
    .header__column--center .search-action form {
      width: 100%;
    }
  }

  :is(.header__column--left) .search-action {
    @media screen and (min-width: 750px) {
      margin-inline: calc(var(--padding-lg) * -1);
    }
  }

  .header__column--right .search-action {
    @media screen and (min-width: 750px) {
      margin-inline: calc(var(--gap-md) * -1) calc(var(--gap-xs) * -1);
    }
  }

  /* Mobile: search bar becomes the full-width header */
  @media screen and (max-width: 749px) {
    .header__column--center .search-action {
      width: 100%;
      height: 40px;
      margin-inline-start: 0;
    }

    /* Make search span the full header width in a second row on mobile */
    .header__columns .search-action {
      grid-area: search;
      width: 100%;
      padding-inline: var(--padding-3xs);
    }

    .header__columns .search-action predictive-search,
    .header__columns .search-action form {
      width: 100%;
    }
  }
{% endstylesheet %}
