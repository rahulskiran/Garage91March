{% comment %}
  Instagram-style Reel Section with Product Linking
  Features: 
  - Desktop: Grid Layout | Mobile: Snap Carousel
  - Customizable Aspect Ratios (9:16, 4:5, 1:1)
  - Autoplay on Scroll (Intersection Observer)
  - Instagram UI Replica (Product as Username)
  - Responsive Padding & Gutter Settings
  - Dynamic Font Selection (Heading & Body)
{% endcomment %}

{%- style -%}
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.body_font | font_face: font_display: 'swap' }}

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    padding-left: {{ section.settings.padding_left_mobile }}px;
    padding-right: {{ section.settings.padding_right_mobile }}px;
  }

  .section-{{ section.id }} .reels-title {
    font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
    font-weight: {{ section.settings.heading_font.weight }};
    font-style: {{ section.settings.heading_font.style }};
  }

  .section-{{ section.id }} .reels-subtitle,
  .section-{{ section.id }} .reel-ui-bottom,
  .section-{{ section.id }} .reel-username,
  .section-{{ section.id }} .reel-follow-btn,
  .section-{{ section.id }} .reel-product-info {
    font-family: {{ section.settings.body_font.family }}, {{ section.settings.body_font.fallback_families }};
    font-weight: {{ section.settings.body_font.weight }};
    font-style: {{ section.settings.body_font.style }};
  }

  .section-{{ section.id }} .reel-card {
    aspect-ratio: {{ section.settings.video_ratio | replace: ':', '/' }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      padding-left: {{ section.settings.padding_left }}px;
      padding-right: {{ section.settings.padding_right }}px;
    }
  }
{%- endstyle -%}

<section class="reels-section section-{{ section.id }} section-{{ section.id }}-padding" data-section-id="{{ section.id }}">
  <div class="page-width">
    {% if section.settings.title != blank %}
      <div class="reels-header">
        <h2 class="reels-title">{{ section.settings.title }}</h2>
        {% if section.settings.subtitle != blank %}
          <p class="reels-subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="reels-container-wrapper">
      <div class="reels-container" id="ReelsContainer-{{ section.id }}">
        {% for block in section.blocks %}
          {%- assign target_link = block.settings.product.url | default: block.settings.collection.url -%}
          
          <div class="reel-card" {{ block.shopify_attributes }}>
            <div class="video-wrapper">
              <video 
                class="reel-video" 
                loop 
                muted 
                playsinline 
                preload="metadata"
                poster="{{ block.settings.cover_image | img_url: '600x' }}">
                <source src="{{ block.settings.video_url }}" type="video/mp4">
              </video>
              
              {% comment %} Redirect Layer {% endcomment %}
              {% if target_link != blank %}
                <a href="{{ target_link }}" class="reel-click-layer" aria-label="View {{ block.settings.product.title }}"></a>
              {% endif %}

              {% comment %} Mute/Unmute UI {% endcomment %}
              <button class="reel-mute-btn" aria-label="Toggle Mute">
                <span class="icon-unmute">
                  <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path></svg>
                </span>
                <span class="icon-mute" style="display:none;">
                  <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><line x1="23" y1="9" x2="17" y2="15"></line><line x1="17" y1="9" x2="23" y2="15"></line></svg>
                </span>
              </button>

              {% comment %} Instagram UI Replica Overlay {% endcomment %}
              <div class="reel-ui-overlay">
                <div class="reel-ui-bottom">
                  <div class="reel-user-info">
                    <div class="reel-avatar">
                      {%- if section.settings.logo != blank -%}
                        <img src="{{ section.settings.logo | img_url: '40x40', crop: 'center' }}" alt="Logo" loading="lazy">
                      {%- else -%}
                        <div class="avatar-placeholder"></div>
                      {%- endif -%}
                    </div>
                    <span class="reel-username">
                      {{ block.settings.product.title | default: block.settings.collection.title | default: "Shop Item" }}
                    </span>
                    <span class="reel-follow-btn">Shop</span>
                  </div>
                  
                  {% if block.settings.product != blank %}
                    <div class="reel-product-info">
                      <span class="reel-price">{{ block.settings.product.price | money }}</span>
                    </div>
                  {% endif %}
                </div>

                <div class="reel-ui-side">
                  <div class="reel-icon"><svg viewBox="0 0 24 24" width="22" height="22" fill="white"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg></div>
                  <div class="reel-icon"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="white" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-10.6 8.38 8.38 0 0 1 3.9.9l4.6-1.5z"/></svg></div>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
  :root {
    --reel-radius: 12px;
    --reel-shadow: 0 8px 30px rgba(0,0,0,0.12);
  }

  .reels-section { 
    background: {{ section.settings.bg_color }}; 
    overflow: hidden;
  }
  
  .reels-header {
    text-align: center;
    margin-bottom: 30px;
  }

  .reels-title { margin: 0; font-size: 2.2rem; letter-spacing: -0.5px; }
  .reels-subtitle { margin-top: 8px; opacity: 0.6; font-size: 1.1rem; }
  
  .reels-container {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .reel-card {
    position: relative;
    border-radius: var(--reel-radius);
    overflow: hidden;
    background: #000;
    box-shadow: var(--reel-shadow);
    transition: transform 0.3s ease;
  }

  .video-wrapper { height: 100%; width: 100%; position: relative; }
  
  .reel-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .reel-click-layer {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 4;
    cursor: pointer;
  }

  .reel-ui-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 40%, transparent 100%);
    pointer-events: none;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 14px;
  }

  .reel-ui-bottom {
    color: white;
  }

  .reel-user-info {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }

  .reel-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    overflow: hidden;
    background: #333;
    border: 1px solid rgba(255,255,255,0.3);
  }
  
  .reel-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .avatar-placeholder { width: 100%; height: 100%; background: linear-gradient(45deg, #f09433, #dc2743, #bc1888); }

  .reel-username {
    font-size: 13px;
    text-shadow: 0 1px 2px rgba(0,0,0,0.5);
    max-width: 110px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .reel-follow-btn {
    font-size: 11px;
    border: 1px solid rgba(255,255,255,0.8);
    padding: 1px 8px;
    border-radius: 4px;
  }

  .reel-product-info { font-size: 13px; }

  .reel-ui-side {
    position: absolute;
    right: 10px;
    bottom: 65px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
  }

  .reel-icon { opacity: 0.95; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.4)); }

  .reel-mute-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    background: rgba(0, 0, 0, 0.4);
    border: none;
    color: white;
    padding: 6px;
    border-radius: 50%;
    cursor: pointer;
    z-index: 10;
    display: flex;
    backdrop-filter: blur(4px);
  }

  @media (max-width: 768px) {
    .reels-container {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 12px;
      padding: 0 {{ section.settings.padding_left_mobile }}px 20px {{ section.settings.padding_right_mobile }}px; 
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .reels-container-wrapper {
      margin-left: -{{ section.settings.padding_left_mobile }}px;
      margin-right: -{{ section.settings.padding_right_mobile }}px;
    }
    .reels-container::-webkit-scrollbar { display: none; }
    
    .reel-card { 
      min-width: 78%; 
      scroll-snap-align: center; 
    }
    .reels-title { font-size: 1.8rem; }
  }
</style>

<script>
  (function() {
    const sectionContainer = document.querySelector('.section-{{ section.id }}');
    if (!sectionContainer) return;

    const videos = sectionContainer.querySelectorAll('.reel-video');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const video = entry.target;
        if (entry.isIntersecting) {
          video.play().catch(() => {});
        } else {
          video.pause();
        }
      });
    }, { threshold: 0.5 });

    videos.forEach(video => observer.observe(video));

    sectionContainer.querySelectorAll('.reel-mute-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const video = btn.closest('.video-wrapper').querySelector('.reel-video');
        video.muted = !video.muted;
        btn.querySelector('.icon-mute').style.display = video.muted ? 'block' : 'none';
        btn.querySelector('.icon-unmute').style.display = video.muted ? 'none' : 'block';
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Instagram Reels Carousel",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop our Reels"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Watch & Shop the latest trends"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading Font",
      "default": "sans-serif"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body Font",
      "default": "sans-serif"
    },
    {
      "type": "select",
      "id": "video_ratio",
      "label": "Video Aspect Ratio",
      "options": [
        { "value": "9:16", "label": "Vertical (9:16)" },
        { "value": "4:5", "label": "Portrait (4:5)" },
        { "value": "1:1", "label": "Square (1:1)" }
      ],
      "default": "9:16"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Account Logo (Avatar)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Left",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Right",
      "default": 20
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_left_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Left Mobile",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Right Mobile",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "reel",
      "name": "Reel",
      "settings": [
        {
          "type": "text",
          "id": "video_url",
          "label": "Video MP4 Link"
        },
        {
          "type": "image_picker",
          "id": "cover_image",
          "label": "Video Poster"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Linked Product"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Linked Collection (Alternative)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Reels Carousel",
      "blocks": [
        { "type": "reel" },
        { "type": "reel" },
        { "type": "reel" },
        { "type": "reel" }
      ]
    }
  ]
}
{% endschema %}