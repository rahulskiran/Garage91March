{%- if section.settings.show_announcement and section.blocks.size > 0 -%}
<div id="g91-bar-{{ section.id }}" class="g91-bar" role="region" aria-label="Announcement" aria-live="polite">
  <div class="g91-bar__track">
    {%- for block in section.blocks -%}
      <div class="g91-bar__slide {% if forloop.first %}g91-bar__slide--visible{% endif %}" 
           data-index="{{ forloop.index0 }}" 
           {{ block.shopify_attributes }}>
        
        {%- if block.settings.show_pulse -%}
          <span class="g91-bar__dot"></span>
        {%- endif -%}

        <div class="g91-bar__content">
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="g91-bar__link">
          {%- endif -%}

            {%- if block.settings.full_text != blank -%}
              <span>{{ block.settings.full_text }}</span>
            {%- else -%}
              {%- if block.settings.text_prefix != blank -%}
                <span>{{ block.settings.text_prefix }}</span>
              {%- endif -%}

              {%- if block.settings.highlight_text != blank -%}
                <span class="g91-bar__hi">{{ block.settings.highlight_text }}</span>
              {%- endif -%}

              {%- if block.settings.text_suffix != blank -%}
                <span>{{ block.settings.text_suffix }}</span>
              {%- endif -%}
            {%- endif -%}

          {%- if block.settings.link != blank -%}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

<style>
  /* ══════════ CSS Variables from Schema ══════════ */
  :root {
    --g91-bg: {{ section.settings.bg_color }};
    --g91-text: {{ section.settings.text_color }};
    --g91-accent: {{ section.settings.accent_color }};
    --g91-fs-desktop: {{ section.settings.text_size }}px;
    --g91-fs-mobile: {{ section.settings.mobile_text_size }}px;
  }

  /* ══════════ Animations ══════════ */
  @keyframes g91-entrance {
    from { transform: translateY(-100%); opacity: 0; }
    to   { transform: translateY(0);     opacity: 1; }
  }
  @keyframes g91-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%      { transform: scale(1.4); opacity: 0.5; }
  }
  @keyframes g91-glow {
    0%, 100% { text-shadow: 0 0 4px {{ section.settings.accent_color | color_modify: 'alpha', 0.3 }}; }
    50%      { text-shadow: 0 0 12px {{ section.settings.accent_color | color_modify: 'alpha', 0.6 }}, 0 0 20px {{ section.settings.accent_color | color_modify: 'alpha', 0.2 }}; }
  }

  /* ══════════ Main Bar ══════════ */
  .g91-bar {
    display: block !important;
    background: var(--g91-bg) !important;
    color: var(--g91-text) !important;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif !important;
    font-size: var(--g91-fs-desktop) !important;
    font-weight: 700 !important;
    letter-spacing: 0.08em !important;
    text-transform: uppercase !important;
    line-height: 1.2 !important;
    position: relative !important;
    z-index: 1000 !important;
    overflow: hidden !important;
    border-bottom: 1px solid rgba(255,255,255,0.1) !important;
    animation: g91-entrance 0.5s ease-out both !important;
    width: 100% !important;
  }

  .g91-bar__track {
    position: relative !important;
    width: 100% !important;
    padding: 14px 20px !important;
    min-height: 48px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  /* ══════════ Slides ══════════ */
  .g91-bar__slide {
    position: absolute !important;
    inset: 0 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 10px !important;
    padding: 10px 20px !important;
    white-space: nowrap !important;
    opacity: 0 !important;
    transform: translateY(100%) !important;
    pointer-events: none !important;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease !important;
  }

  .g91-bar__slide--visible {
    opacity: 1 !important;
    transform: translateY(0) !important;
    pointer-events: auto !important;
    position: relative !important;
  }

  .g91-bar__slide--out {
    opacity: 0 !important;
    transform: translateY(-100%) !important;
  }

  .g91-bar__slide--in {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

  /* ══════════ Content Elements ══════════ */
  .g91-bar__content {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .g91-bar__link {
    color: inherit;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: opacity 0.2s ease;
  }
  
  .g91-bar__link:hover {
    opacity: 0.8;
  }

  .g91-bar__hi {
    color: var(--g91-accent) !important;
    animation: g91-glow 2s ease-in-out infinite !important;
  }

  .g91-bar__dot {
    display: inline-block !important;
    width: 8px !important;
    height: 8px !important;
    border-radius: 50% !important;
    background: var(--g91-accent) !important;
    box-shadow: 0 0 10px var(--g91-accent);
    flex-shrink: 0 !important;
    animation: g91-pulse 1.5s ease-in-out infinite !important;
  }

  /* ══════════ Mobile Adjustments ══════════ */
  @media (max-width: 749px) {
    .g91-bar {
      font-size: var(--g91-fs-mobile) !important;
      letter-spacing: 0.05em !important;
    }
    .g91-bar__slide {
      white-space: normal !important;
      text-align: center !important;
      flex-wrap: wrap;
      gap: 6px !important;
    }
    .g91-bar__track {
      padding: 12px 15px !important;
    }
  }
</style>

<script>
(function(){
  const container = document.getElementById('g91-bar-{{ section.id }}');
  if (!container) return;
  
  const items = container.querySelectorAll('.g91-bar__slide');
  if (items.length < 2) return;

  let currentIndex = 0;
  const totalItems = items.length;
  const intervalTime = {{ section.settings.cycle_speed | default: 5 }} * 1000;
  let isMoving = false;

  function performTransition() {
    if (isMoving) return;
    isMoving = true;

    const currentSlide = items[currentIndex];
    const nextIndex = (currentIndex + 1) % totalItems;
    const nextSlide = items[nextIndex];

    // Outgoing animation
    currentSlide.classList.remove('g91-bar__slide--visible');
    currentSlide.classList.add('g91-bar__slide--out');

    // Prepare next slide position
    nextSlide.style.transition = 'none';
    nextSlide.style.transform = 'translateY(100%)';
    nextSlide.style.opacity = '0';
    nextSlide.classList.remove('g91-bar__slide--out');
    
    // Trigger reflow
    void nextSlide.offsetHeight;

    // Incoming animation
    nextSlide.style.transition = '';
    nextSlide.classList.add('g91-bar__slide--in');

    currentIndex = nextIndex;

    setTimeout(() => {
      currentSlide.classList.remove('g91-bar__slide--out');
      nextSlide.classList.remove('g91-bar__slide--in');
      nextSlide.classList.add('g91-bar__slide--visible');
      isMoving = false;
    }, 550);
  }

  let slideInterval = setInterval(performTransition, intervalTime);

  // Theme Editor handling: Reset interval when user edits blocks
  if (window.Shopify && Shopify.designMode) {
    document.addEventListener('shopify:section:select', () => {
       clearInterval(slideInterval);
       slideInterval = setInterval(performTransition, intervalTime);
    });
    
    document.addEventListener('shopify:block:select', (event) => {
       clearInterval(slideInterval);
       const blockIndex = parseInt(event.target.getAttribute('data-index'));
       
       items.forEach(slide => {
         slide.classList.remove('g91-bar__slide--visible', 'g91-bar__slide--out', 'g91-bar__slide--in');
       });
       
       items[blockIndex].classList.add('g91-bar__slide--visible');
       currentIndex = blockIndex;
    });

    document.addEventListener('shopify:block:deselect', () => {
       slideInterval = setInterval(performTransition, intervalTime);
    });
  }
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Custom Announcement Bar",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (Glow)",
      "default": "#EA580C"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Desktop text size",
      "default": 13
    },
    {
      "type": "range",
      "id": "mobile_text_size",
      "min": 8,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Mobile text size",
      "default": 11
    },
    {
      "type": "header",
      "content": "Message Cycling"
    },
    {
      "type": "range",
      "id": "cycle_speed",
      "min": 2,
      "max": 15,
      "step": 1,
      "unit": "s",
      "label": "Seconds per message",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Message",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_pulse",
          "label": "Show LIVE pulse dot",
          "default": false
        },
        {
          "type": "header",
          "content": "Option 1: Single Line Text",
          "info": "Overrides split text if this field is filled."
        },
        {
          "type": "text",
          "id": "full_text",
          "label": "Full message text",
          "placeholder": "Enter your message here..."
        },
        {
          "type": "header",
          "content": "Option 2: Split Text (with Highlight)",
          "info": "Use this to apply the accent color glow to a specific word."
        },
        {
          "type": "text",
          "id": "text_prefix",
          "label": "Text before highlight",
          "default": "Join the"
        },
        {
          "type": "text",
          "id": "highlight_text",
          "label": "Highlighted text (Accent)",
          "default": "Riders Club"
        },
        {
          "type": "text",
          "id": "text_suffix",
          "label": "Text after highlight",
          "default": "Today"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Announcement Bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text_prefix": "60,000+",
            "highlight_text": "Followers",
            "text_suffix": "on Instagram",
            "show_pulse": true
          }
        },
        {
          "type": "announcement",
          "settings": {
            "full_text": "Free Shipping on All Orders Over ₹2,999"
          }
        }
      ]
    }
  ]
}
{% endschema %}