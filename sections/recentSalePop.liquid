{% comment %}
  Recent Sale Popup Section for Shopify
  Location: sections/recent-sale-popup.liquid
{% endcomment %}

{%- assign section_id_clean = section.id | replace: '-', '_' | replace: '--', '_' -%}
{%- assign selected_collection = collections[section.settings.collection] -%}

<style>
  {{ section.settings.font_family | font_face }}

  #recent-sale-container-{{ section.id }} {
    position: fixed;
    bottom: 20px;
    left: 20px;
    width: {{ section.settings.popup_width }}px;
    max-width: calc(100vw - 40px);
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    font-family: {{ section.settings.font_family.family }}, {{ section.settings.font_family.fallback_families }};
    border-radius: {{ section.settings.border_radius }}px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    overflow: hidden;
    z-index: 9999;
    display: none; 
    transform: translateY(100px);
    transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    border: 1px solid rgba(0,0,0,0.05);
  }

  #recent-sale-container-{{ section.id }}.active {
    display: flex;
    transform: translateY(0);
  }

  .rs-bg-overlay-{{ section.id }} {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | img_url: 'master' }}');
      background-size: cover;
      background-position: center;
    {% endif %}
    z-index: -1;
  }
  
  .rs-bg-color-tint-{{ section.id }} {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: {{ section.settings.bg_color }};
    opacity: {{ 100 | minus: section.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: -1;
  }

  .rs-content {
    display: flex;
    align-items: center;
    padding: 15px;
    gap: 15px;
    width: 100%;
    position: relative;
  }

  .rs-image-box {
    width: 65px;
    height: 65px;
    flex-shrink: 0;
    border-radius: 6px;
    background: #f9f9f9;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(0,0,0,0.05);
  }

  .rs-image-box img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .rs-info {
    flex-grow: 1;
    line-height: 1.4;
  }

  .rs-title {
    font-size: {{ section.settings.font_size_main }}px;
    margin: 0;
    font-weight: 500;
  }

  .rs-title span.city {
    color: {{ section.settings.city_color }};
    font-weight: 700;
  }

  .rs-meta {
    font-size: {{ section.settings.font_size_sub }}px;
    opacity: 0.7;
    margin-top: 4px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .rs-verified-badge {
    font-size: 10px; 
    font-weight: 600;
    color: {{ section.settings.verified_color }};
  }

  .rs-close {
    position: absolute;
    top: 8px;
    right: 8px;
    cursor: pointer;
    font-size: 16px;
    opacity: 0.5;
    z-index: 2;
  }

  @media (max-width: 480px) {
    #recent-sale-container-{{ section.id }} {
      bottom: 10px;
      left: 10px;
      width: calc(100% - 20px);
    }
  }
</style>

<div id="recent-sale-container-{{ section.id }}">
  <div class="rs-bg-overlay-{{ section.id }}"></div>
  <div class="rs-bg-color-tint-{{ section.id }}"></div>
  <div class="rs-close" onclick="window.closeRecentSale_{{ section_id_clean }}()">×</div>
  
  <div class="rs-content">
    <div class="rs-image-box">
      <img id="rs-product-image-{{ section.id }}" src="" alt="Product Image">
    </div>
    <div class="rs-info">
      <p class="rs-title">
        <span id="rs-user-name-{{ section.id }}">Someone</span> from <span id="rs-city-{{ section.id }}" class="city">India</span> 
        bought <span id="rs-product-{{ section.id }}" style="font-weight:600;">item</span>
      </p>
      <div class="rs-meta">
        <span id="rs-time-{{ section.id }}">2 minutes ago</span>
        <span class="rs-verified-badge">Verified ✓</span>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    // Real Product Data from Collection
    const storeProducts = [
      {% if selected_collection != blank %}
        {% for product in selected_collection.products limit: 20 %}
          {
            title: {{ product.title | json }},
            image: {{ product.featured_image | img_url: '200x200', crop: 'center' | json }}
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      {% else %}
        {% for product in collections.all.products limit: 20 %}
          {
            title: {{ product.title | json }},
            image: {{ product.featured_image | img_url: '200x200', crop: 'center' | json }}
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      {% endif %}
    ];

    const indianCities = ["Mumbai", "Delhi", "Bangalore", "Hyderabad", "Ahmedabad", "Chennai", "Kolkata", "Surat", "Pune", "Jaipur", "Lucknow", "Kanpur", "Nagpur", "Indore", "Thane", "Bhopal", "Visakhapatnam", "Patna", "Vadodara", "Ghaziabad", "Ludhiana", "Agra", "Nashik", "Faridabad", "Meerut", "Rajkot", "Varanasi", "Amritsar", "Navi Mumbai", "Ranchi", "Gwalior", "Jabalpur", "Coimbatore", "Vijayawada", "Jodhpur", "Madurai", "Raipur", "Kota", "Chandigarh", "Guwahati"];

    const indianNames = ["Arjun", "Priyanka", "Rajesh", "Sneha", "Vikram", "Anjali", "Siddharth", "Kavita", "Amit", "Deepika", "Rohan", "Meera", "Pooja", "Varun", "Ishani", "Aakash", "Bhavna", "Chirag", "Divya", "Eshwar"];

    function maskName(name) {
      const halfLen = Math.max(2, Math.floor(name.length / 2));
      return name.substring(0, halfLen) + "***";
    }

    function getRandomInt(min, max) {
      return Math.floor(Math.random() * (max - min + 1)) + min;
    }

    window.showRecentSale_{{ section_id_clean }} = function() {
      const container = document.getElementById('recent-sale-container-{{ section.id }}');
      if(!container || storeProducts.length === 0) return;

      const product = storeProducts[Math.floor(Math.random() * storeProducts.length)];
      
      document.getElementById('rs-user-name-{{ section.id }}').innerText = maskName(indianNames[Math.floor(Math.random() * indianNames.length)]);
      document.getElementById('rs-city-{{ section.id }}').innerText = indianCities[Math.floor(Math.random() * indianCities.length)];
      document.getElementById('rs-product-{{ section.id }}').innerText = product.title;
      document.getElementById('rs-product-image-{{ section.id }}').src = product.image;
      
      const isMinutes = Math.random() > 0.3;
      const timeVal = isMinutes ? getRandomInt(1, 59) : getRandomInt(1, 12);
      document.getElementById('rs-time-{{ section.id }}').innerText = `${timeVal} ${isMinutes ? 'minutes' : 'hours'} ago`;

      container.classList.add('active');
      setTimeout(() => { window.closeRecentSale_{{ section_id_clean }}(); }, 6000);
    };

    window.closeRecentSale_{{ section_id_clean }} = function() {
      const container = document.getElementById('recent-sale-container-{{ section.id }}');
      if(container) container.classList.remove('active');
    };

    document.addEventListener('DOMContentLoaded', function() {
      const initialDelay = {{ section.settings.initial_delay | default: 5 | times: 1000 }};
      const displayInterval = {{ section.settings.display_interval | default: 20 | times: 1000 }};

      setTimeout(window.showRecentSale_{{ section_id_clean }}, initialDelay);
      
      setInterval(() => {
        const container = document.getElementById('recent-sale-container-{{ section.id }}');
        if (container && !container.classList.contains('active')) {
          window.showRecentSale_{{ section_id_clean }}();
        }
      }, displayInterval);
    });
  })();
</script>

{% schema %}
{
  "name": "Recent Sale Popup",
  "settings": [
    {
      "type": "header",
      "content": "Product Source"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection",
      "info": "The popup will show products from this collection. Leave empty to show 'All Products'."
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "popup_width",
      "min": 250,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Popup Width",
      "default": 350
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Corner Roundness",
      "default": 12
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Choose Font",
      "default": "helvetica_n4"
    },
    {
      "type": "range",
      "id": "font_size_main",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Main Text Size",
      "default": 14
    },
    {
      "type": "range",
      "id": "font_size_sub",
      "min": 8,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "Sub Text Size",
      "default": 12
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "city_color",
      "label": "City Name Color",
      "default": "#e67e22"
    },
    {
      "type": "color",
      "id": "verified_color",
      "label": "Verified Status Color",
      "default": "#27ae60"
    },
    {
      "type": "header",
      "content": "Background Image Overlay"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image (Optional)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Image Visibility (Overlay)",
      "default": 10
    },
    {
      "type": "header",
      "content": "Timing"
    },
    {
      "type": "range",
      "id": "initial_delay",
      "min": 1,
      "max": 30,
      "step": 1,
      "unit": "sec",
      "label": "Initial Delay",
      "default": 5
    },
    {
      "type": "range",
      "id": "display_interval",
      "min": 5,
      "max": 60,
      "step": 1,
      "unit": "sec",
      "label": "Display Every X Seconds",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Recent Sale Popup"
    }
  ]
}
{% endschema %}