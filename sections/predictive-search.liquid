<script>
  // Tab switching logic – runs after morph updates
  document.addEventListener('click', (e) => {
    const tab = e.target.closest('[data-tab]');
    if (!tab) return;
    
    const tabsContainer = tab.closest('[data-search-tabs]');
    if (!tabsContainer) return;
    
    const resultsInner = tabsContainer.closest('.predictive-search-results__inner');
    if (!resultsInner) return;
    
    const activeTab = tab.dataset.tab;
    
    // Update active tab button
    tabsContainer.querySelectorAll('.search-tabs__tab').forEach(t => {
      t.classList.toggle('search-tabs__tab--active', t === tab);
    });
    
    // Show/hide content sections
    resultsInner.querySelectorAll('[data-search-tab-content]').forEach(section => {
      const sectionType = section.dataset.searchTabContent;
      
      if (activeTab === 'all') {
        section.classList.remove('search-tab--hidden');
      } else if (sectionType === activeTab) {
        section.classList.remove('search-tab--hidden');
      } else {
        section.classList.add('search-tab--hidden');
      }
    });
  });
</script>

