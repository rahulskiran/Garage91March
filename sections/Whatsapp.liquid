{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}
{% assign unique_id = 'ai-whatsapp-' | append: ai_gen_id %}

{% style %}
  /* Initial state: hidden to prevent flash before move */
  #{{ unique_id }} {
    display: none; 
  }

  /* Styling for the moved container */
  #{{ unique_id }}.moved-to-body {
    display: block;
    position: fixed !important;
    bottom: {{ section.settings.bottom_position }}px;
    right: {{ section.settings.right_position }}px;
    z-index: 2147483647 !important; /* Max integer value */
    line-height: 0;
    pointer-events: none; /* Let clicks pass through the container area */
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));
  }

  /* The actual clickable link */
  #{{ unique_id }} .ai-wa-link {
    pointer-events: auto; /* Re-enable clicks on the button */
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ section.settings.button_size }}px;
    height: {{ section.settings.button_size }}px;
    border-radius: {{ section.settings.border_radius }}px;
    background-color: {{ section.settings.background_color }};
    text-decoration: none;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  #{{ unique_id }} .ai-wa-link:hover {
    transform: scale(1.1);
  }

  /* Animation Layers */
  #{{ unique_id }} .ai-wa-ring {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: {{ section.settings.border_radius }}px;
    border: 2px solid {{ section.settings.background_color }};
    opacity: 0;
    z-index: -1;
  }

  {% if section.settings.animation_style == 'ring' %}
    #{{ unique_id }} .ai-wa-ring:nth-child(1) { animation: ai-wa-ripple 2s infinite; }
    #{{ unique_id }} .ai-wa-ring:nth-child(2) { animation: ai-wa-ripple 2s infinite 0.6s; }
    
    @keyframes ai-wa-ripple {
      0% { transform: scale(1); opacity: 0.7; }
      100% { transform: scale(1.6); opacity: 0; }
    }
  {% elsif section.settings.animation_style == 'shake' %}
    #{{ unique_id }} .ai-wa-link { animation: ai-wa-shake 4s infinite; }
    
    @keyframes ai-wa-shake {
      0%, 100% { transform: rotate(0deg); }
      90% { transform: rotate(0deg); }
      92% { transform: rotate(-10deg); }
      94% { transform: rotate(10deg); }
      96% { transform: rotate(-10deg); }
      98% { transform: rotate(10deg); }
    }
  {% elsif section.settings.animation_style == 'pulse' %}
    #{{ unique_id }} .ai-wa-link { animation: ai-wa-pulse 2s infinite; }
    
    @keyframes ai-wa-pulse {
      0% { box-shadow: 0 0 0 0 rgba({{ section.settings.background_color | color_extract: 'red' }}, {{ section.settings.background_color | color_extract: 'green' }}, {{ section.settings.background_color | color_extract: 'blue' }}, 0.7); }
      70% { box-shadow: 0 0 0 20px rgba({{ section.settings.background_color | color_extract: 'red' }}, {{ section.settings.background_color | color_extract: 'green' }}, {{ section.settings.background_color | color_extract: 'blue' }}, 0); }
      100% { box-shadow: 0 0 0 0 rgba(0, 0, 0, 0); }
    }
  {% endif %}

  /* Icon Styling */
  #{{ unique_id }} .ai-wa-icon {
    width: 60%;
    height: 60%;
    object-fit: contain;
    fill: {{ section.settings.icon_color }};
    color: {{ section.settings.icon_color }};
  }

  /* Popup / Tooltip Styling */
  #{{ unique_id }} .ai-wa-popup {
    position: absolute;
    right: 100%;
    top: 50%;
    transform: translateY(-50%) translateX(-15px);
    background: {{ section.settings.tooltip_background }};
    color: {{ section.settings.tooltip_text_color }};
    padding: 10px 18px;
    border-radius: 20px;
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    font-size: {{ section.settings.tooltip_font_size }}px;
    font-weight: 600;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    pointer-events: none;
  }
  
  /* Small arrow for popup */
  #{{ unique_id }} .ai-wa-popup::after {
    content: '';
    position: absolute;
    top: 50%;
    right: -6px;
    margin-top: -6px;
    border-width: 6px 0 6px 6px;
    border-style: solid;
    border-color: transparent transparent transparent {{ section.settings.tooltip_background }};
  }

  /* Hover state */
  #{{ unique_id }} .ai-wa-link:hover .ai-wa-popup {
    opacity: 1;
    visibility: visible;
    transform: translateY(-50%) translateX(-10px);
  }

  /* Mobile Adjustments */
  @media screen and (max-width: 768px) {
    #{{ unique_id }}.moved-to-body {
      bottom: {{ section.settings.bottom_position | times: 0.8 }}px;
      right: {{ section.settings.right_position | times: 0.8 }}px;
    }
    #{{ unique_id }} .ai-wa-link {
      width: {{ section.settings.button_size | times: 0.9 }}px;
      height: {{ section.settings.button_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<!-- Main Container -->
<div id="{{ unique_id }}" class="ai-whatsapp-widget" {{ section.shopify_attributes }}>
  <a href="https://wa.me/{{ section.settings.phone_number }}?text={{ section.settings.message | url_encode }}" 
     target="_blank" 
     class="ai-wa-link"
     aria-label="Chat on WhatsApp">
    
    <!-- Animation Rings -->
    <div class="ai-wa-ring"></div>
    <div class="ai-wa-ring"></div>
    
    <!-- Icon -->
    {% if section.settings.custom_icon %}
      <img src="{{ section.settings.custom_icon | image_url: width: 100 }}" class="ai-wa-icon" alt="WhatsApp" loading="lazy">
    {% else %}
      <svg class="ai-wa-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" fill="currentColor"></path></svg>
    {% endif %}

    <!-- Popup Text -->
    {% if section.settings.show_tooltip %}
      <div class="ai-wa-popup">
        {{ section.settings.tooltip_text }}
      </div>
    {% endif %}
  </a>
</div>

<script>
  (function() {
    function moveWhatsAppWidget() {
      var widget = document.getElementById('{{ unique_id }}');
      if (widget && document.body) {
        // Append to body to break out of all stacking contexts
        document.body.appendChild(widget);
        widget.classList.add('moved-to-body');
      }
    }
    
    // Execute immediately if body exists, otherwise wait for load
    if (document.body) {
      moveWhatsAppWidget();
    } else {
      document.addEventListener('DOMContentLoaded', moveWhatsAppWidget);
    }

    // Handle Shopify Theme Editor events to keep it working in the customizer
    if (window.Shopify && Shopify.designMode) {
      document.addEventListener('shopify:section:load', moveWhatsAppWidget);
      document.addEventListener('shopify:section:select', moveWhatsAppWidget);
    }
  })();
</script>

{% schema %}
{
  "name": "WhatsApp Widget",
  "settings": [
    {
      "type": "header",
      "content": "Configuration"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number (with country code)",
      "default": "15551234567"
    },
    {
      "type": "text",
      "id": "message",
      "label": "Welcome Message",
      "default": "Hi! I'd like to talk to Trove."
    },
    {
      "type": "header",
      "content": "Popup / Tooltip"
    },
    {
      "type": "checkbox",
      "id": "show_tooltip",
      "label": "Show Popup Text",
      "default": true
    },
    {
      "type": "text",
      "id": "tooltip_text",
      "label": "Popup Text",
      "default": "Talk to Trove"
    },
    {
      "type": "color",
      "id": "tooltip_background",
      "label": "Popup Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "tooltip_text_color",
      "label": "Popup Text Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "tooltip_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "label": "Popup Font Size",
      "default": 14
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "image_picker",
      "id": "custom_icon",
      "label": "Custom Icon Image"
    },
    {
      "type": "select",
      "id": "animation_style",
      "label": "Animation Effect",
      "options": [
        { "value": "ring", "label": "Ripple Rings" },
        { "value": "shake", "label": "Shake" },
        { "value": "pulse", "label": "Pulse" },
        { "value": "none", "label": "None" }
      ],
      "default": "ring"
    },
    {
      "type": "range",
      "id": "button_size",
      "min": 40,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Button Size",
      "default": 60
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Corner Radius (50px = Round)",
      "default": 50
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Button Color",
      "default": "#25D366"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Positioning"
    },
    {
      "type": "range",
      "id": "bottom_position",
      "min": 10,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Distance from Bottom",
      "default": 20
    },
    {
      "type": "range",
      "id": "right_position",
      "min": 10,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Distance from Right",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "WhatsApp Widget"
    }
  ]
}
{% endschema %}