{% comment %}
  Garage91 — Night Drive Announcement Bar
  Carbon Black, steel grey type, Garage Orange CTAs, Neon Volt hover glow,
  cinematic cross-fade rotation, heavy garage-curtain entrance.
{% endcomment %}

{%- if section.settings.show_announcement and section.blocks.size > 0 -%}
<div id="g91-bar-{{ section.id }}" class="g91-bar" role="region" aria-label="Announcement" aria-live="polite">
  <div class="g91-bar__track">
    {%- for block in section.blocks -%}
      <div class="g91-bar__slide{% if forloop.first %} g91-bar__slide--active{% endif %}"
           data-index="{{ forloop.index0 }}"
           {{ block.shopify_attributes }}>

        {%- if block.settings.show_pulse -%}
          <span class="g91-bar__pulse" aria-hidden="true"></span>
        {%- endif -%}

        {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}" class="g91-bar__a">{%- endif -%}

          {%- if block.settings.full_text != blank -%}
            <span class="g91-bar__txt">{{ block.settings.full_text }}</span>
          {%- else -%}
            {%- if block.settings.text_prefix != blank -%}
              <span class="g91-bar__txt">{{ block.settings.text_prefix }}</span>
            {%- endif -%}
            {%- if block.settings.highlight_text != blank -%}
              <span class="g91-bar__hi">{{ block.settings.highlight_text }}</span>
            {%- endif -%}
            {%- if block.settings.text_suffix != blank -%}
              <span class="g91-bar__txt">{{ block.settings.text_suffix }}</span>
            {%- endif -%}
          {%- endif -%}

          {%- if block.settings.link != blank -%}
            <span class="g91-bar__arrow" aria-hidden="true">→</span>
          </a>{%- endif -%}

      </div>
    {%- endfor -%}
  </div>
</div>

<style>
  /* ═══════ ENTRANCE — garage curtain drop ═══════ */
  @keyframes g91Drop {
    0%   { transform: translateY(-100%); opacity: 0; }
    60%  { transform: translateY(4%);    opacity: 1; }
    80%  { transform: translateY(-1%);   opacity: 1; }
    100% { transform: translateY(0);     opacity: 1; }
  }

  /* ═══════ LIVE dot pulse ═══════ */
  @keyframes g91Pulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(234,88,12,.5); }
    50%     { box-shadow: 0 0 0 5px rgba(234,88,12,0); }
  }

  /* ═══════ BAR ═══════ */
  #g91-bar-{{ section.id }} {
    --g91-carbon:  #111111;
    --g91-steel:   #B0B0B0;
    --g91-orange:  #EA580C;
    --g91-volt:    #E5FF00;

    display: block;
    width: 100%;
    background: var(--g91-carbon) !important;
    background-color: var(--g91-carbon) !important;
    position: relative;
    z-index: 4;
    overflow: hidden;
    border-bottom: 1px solid rgba(255,255,255,.04);
    animation: g91Drop .65s cubic-bezier(.22,.68,.36,1) both;
  }
  /* Override any theme variables bleeding in */
  #g91-bar-{{ section.id }},
  #g91-bar-{{ section.id }} * {
    --color-background: 17,17,17 !important;
    --color-foreground: 176,176,176 !important;
    --color-background-rgb: 17,17,17 !important;
    --color-foreground-rgb: 176,176,176 !important;
    box-sizing: border-box;
  }

  /* ═══════ TRACK ═══════ */
  .g91-bar__track {
    position: relative;
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
  }

  /* ═══════ SLIDES — cinematic cross-fade ═══════ */
  .g91-bar__slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    padding: 11px 24px;
    white-space: nowrap;

    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    font-size: {{ section.settings.text_size }}px;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    line-height: 1.35;
    color: var(--g91-steel);

    opacity: 0;
    visibility: hidden;
    transition: opacity .6s ease, visibility 0s .6s;
    pointer-events: none;
  }

  .g91-bar__slide--active {
    position: relative;          /* sets container height */
    opacity: 1;
    visibility: visible;
    transition: opacity .6s ease, visibility 0s 0s;
    pointer-events: auto;
  }

  /* ═══════ TEXT ═══════ */
  .g91-bar__txt {
    color: var(--g91-steel);
  }

  /* Highlighted text — Garage Orange */
  .g91-bar__hi {
    color: var(--g91-orange) !important;
  }

  /* ═══════ LINK ═══════ */
  .g91-bar__a {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: inherit !important;
    text-decoration: none !important;
    background: none !important;
  }
  .g91-bar__a .g91-bar__hi,
  .g91-bar__a .g91-bar__txt {
    transition: color .2s ease;
  }
  .g91-bar__a:hover .g91-bar__hi,
  .g91-bar__a:hover .g91-bar__txt {
    color: var(--g91-volt) !important;
    text-shadow: 0 0 14px rgba(229,255,0,.35), 0 0 28px rgba(229,255,0,.15);
  }

  /* Arrow — appears on links, nudges right on hover */
  .g91-bar__arrow {
    display: inline-block;
    font-size: .85em;
    color: var(--g91-orange);
    transition: transform .25s ease, color .2s ease;
  }
  .g91-bar__a:hover .g91-bar__arrow {
    transform: translateX(4px);
    color: var(--g91-volt);
    text-shadow: 0 0 10px rgba(229,255,0,.4);
  }

  /* ═══════ LIVE PULSE DOT ═══════ */
  .g91-bar__pulse {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--g91-orange);
    flex-shrink: 0;
    margin-right: 3px;
    animation: g91Pulse 1.5s ease-in-out infinite;
  }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 749px) {
    .g91-bar__slide {
      font-size: {{ section.settings.mobile_text_size }}px;
      letter-spacing: .07em;
      padding: 10px 14px;
      gap: 5px;
    }
    .g91-bar__track {
      min-height: 38px;
    }
  }

  @media (max-width: 420px) {
    .g91-bar__slide {
      white-space: normal;
      text-align: center;
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>

<script>
(function () {
  var bar = document.getElementById('g91-bar-{{ section.id }}');
  if (!bar) return;
  var slides = bar.querySelectorAll('.g91-bar__slide');
  if (slides.length < 2) return;

  var idx  = 0,
      len  = slides.length,
      ms   = {{ section.settings.cycle_speed | default: 5 }} * 1000,
      busy = false;

  function fade() {
    if (busy) return;
    busy = true;

    var cur = slides[idx];
    var nxt = slides[(idx + 1) % len];

    /* cross-fade: old fades out, new fades in simultaneously */
    cur.classList.remove('g91-bar__slide--active');
    nxt.classList.add('g91-bar__slide--active');

    idx = (idx + 1) % len;

    setTimeout(function () { busy = false; }, 650);
  }

  var timer = setInterval(fade, ms);

  /* Shopify editor compat */
  if (window.Shopify && Shopify.designMode) {
    document.addEventListener('shopify:section:select', function () {
      clearInterval(timer);
      timer = setInterval(fade, ms);
    });
  }
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "header",
      "content": "── Typography ──"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Desktop text size",
      "default": 12
    },
    {
      "type": "range",
      "id": "mobile_text_size",
      "min": 8,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Mobile text size",
      "default": 10
    },
    {
      "type": "header",
      "content": "── Message Cycling ──"
    },
    {
      "type": "range",
      "id": "cycle_speed",
      "min": 2,
      "max": 15,
      "step": 1,
      "unit": "s",
      "label": "Seconds per message",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Message",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_pulse",
          "label": "Show LIVE pulse dot",
          "default": false
        },
        {
          "type": "header",
          "content": "── Simple Mode ──",
          "info": "Fill this for a plain message. Leave blank to use split text below."
        },
        {
          "type": "text",
          "id": "full_text",
          "label": "Full message text"
        },
        {
          "type": "header",
          "content": "── Split Text (with highlight) ──"
        },
        {
          "type": "text",
          "id": "text_prefix",
          "label": "Text before highlight"
        },
        {
          "type": "text",
          "id": "highlight_text",
          "label": "Highlighted text (orange)"
        },
        {
          "type": "text",
          "id": "text_suffix",
          "label": "Text after highlight"
        },
        {
          "type": "header",
          "content": "── Link ──"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar – Night Drive",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text_prefix": "🏁",
            "highlight_text": "60,000+",
            "text_suffix": "Strong on Instagram",
            "show_pulse": true,
            "link": "https://instagram.com"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "full_text": "🚚  Free Shipping on All Orders Over ₹2,999"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text_prefix": "🏍",
            "highlight_text": "Riders Club",
            "text_suffix": "— Join the Pack",
            "link": "/pages/riders-club"
          }
        }
      ]
    }
  ]
}
{% endschema %}