{%- if section.settings.show_announcement and section.blocks.size > 0 -%}
<div id="g91-bar-{{ section.id }}" class="g91-bar" role="region" aria-label="Announcement" aria-live="polite">
  <div class="g91-bar__track">
    {%- for block in section.blocks -%}
      <div class="g91-bar__slide {% if forloop.first %}g91-bar__slide--visible{% endif %}" 
           data-index="{{ forloop.index0 }}" 
           {{ block.shopify_attributes }}>
        
        {%- if block.settings.show_pulse -%}
          <span class="g91-bar__dot"></span>
        {%- endif -%}

        <div class="g91-bar__content">
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="g91-bar__link">
          {%- endif -%}

            {%- if block.settings.text_prefix != blank -%}
              <span>{{ block.settings.text_prefix }}</span>
            {%- endif -%}

            {%- if block.settings.highlight_text != blank -%}
              <span class="g91-bar__hi">{{ block.settings.highlight_text }}</span>
            {%- endif -%}

            {%- if block.settings.text_suffix != blank -%}
              <span>{{ block.settings.text_suffix }}</span>
            {%- endif -%}

          {%- if block.settings.link != blank -%}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

<style>
  /* ══════════ Dynamic Variables ══════════ */
  :root {
    --g91-bg: {{ section.settings.bg_color }};
    --g91-text: {{ section.settings.text_color }};
    --g91-accent: {{ section.settings.accent_color }};
    --g91-fs-desktop: {{ section.settings.text_size }}px;
    --g91-fs-mobile: {{ section.settings.mobile_text_size }}px;
  }

  /* ══════════ Keyframes ══════════ */
  @keyframes g91-entrance {
    from { transform: translateY(-100%); opacity: 0; }
    to   { transform: translateY(0);     opacity: 1; }
  }
  @keyframes g91-pulse {
    0%,100% { transform: scale(1);   opacity: 1; }
    50%     { transform: scale(1.4); opacity: .5; }
  }
  @keyframes g91-glow {
    0%,100% { text-shadow: 0 0 4px {{ section.settings.accent_color | color_modify: 'alpha', 0.35 }}; }
    50%     { text-shadow: 0 0 12px {{ section.settings.accent_color | color_modify: 'alpha', 0.65 }}, 0 0 24px {{ section.settings.accent_color | color_modify: 'alpha', 0.25 }}; }
  }

  /* ══════════ Bar Layout ══════════ */
  .g91-bar {
    display: block !important;
    background: var(--g91-bg) !important;
    color: var(--g91-text) !important;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif !important;
    font-size: var(--g91-fs-desktop) !important;
    font-weight: 600 !important;
    letter-spacing: .09em !important;
    text-transform: uppercase !important;
    line-height: 1.4 !important;
    position: relative !important;
    z-index: 999 !important;
    overflow: hidden !important;
    border-bottom: 1px solid rgba(255,255,255,.05) !important;
    animation: g91-entrance .4s ease-out both !important;
    width: 100% !important;
  }

  .g91-bar__track {
    position: relative !important;
    width: 100% !important;
    padding: 12px 20px !important;
    min-height: 44px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  .g91-bar__slide {
    position: absolute !important;
    inset: 0 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 8px !important;
    padding: 10px 20px !important;
    white-space: nowrap !important;
    opacity: 0 !important;
    transform: translateY(110%) !important;
    pointer-events: none !important;
    transition: transform .45s cubic-bezier(.4,0,.2,1), opacity .45s ease !important;
  }

  .g91-bar__slide--visible {
    opacity: 1 !important;
    transform: translateY(0) !important;
    pointer-events: auto !important;
    position: relative !important;
  }

  .g91-bar__slide--out {
    opacity: 0 !important;
    transform: translateY(-110%) !important;
  }

  .g91-bar__slide--in {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

  /* ══════════ Content Styles ══════════ */
  .g91-bar__content {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .g91-bar__link {
    color: inherit;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .g91-bar__hi {
    color: var(--g91-accent) !important;
    animation: g91-glow 2.5s ease-in-out infinite !important;
  }

  .g91-bar__dot {
    display: inline-block !important;
    width: 6px !important;
    height: 6px !important;
    border-radius: 50% !important;
    background: var(--g91-accent) !important;
    flex-shrink: 0 !important;
    animation: g91-pulse 1.4s ease-in-out infinite !important;
  }

  /* ══════════ Mobile ══════════ */
  @media (max-width: 749px) {
    .g91-bar {
      font-size: var(--g91-fs-mobile) !important;
      letter-spacing: .05em !important;
    }
    .g91-bar__slide {
      white-space: normal !important;
      text-align: center !important;
      flex-wrap: wrap;
    }
  }
</style>

<script>
(function(){
  const root = document.getElementById('g91-bar-{{ section.id }}');
  if (!root) return;
  const slides = root.querySelectorAll('.g91-bar__slide');
  if (slides.length < 2) return;

  let i = 0;
  const n = slides.length;
  const wait = {{ section.settings.cycle_speed | default: 5 }} * 1000;
  let lock = false;

  function rotate() {
    if (lock) return;
    lock = true;

    const cur = slides[i];
    const nextIndex = (i + 1) % n;
    const next = slides[nextIndex];

    // Slide current OUT
    cur.classList.remove('g91-bar__slide--visible');
    cur.classList.add('g91-bar__slide--out');

    // Reset next position instantly
    next.style.transition = 'none';
    next.style.transform = 'translateY(110%)';
    next.style.opacity = '0';
    next.classList.remove('g91-bar__slide--out');
    
    void next.offsetHeight; // Force reflow

    // Slide next IN
    next.style.transition = '';
    next.classList.add('g91-bar__slide--in');

    i = nextIndex;

    setTimeout(() => {
      cur.classList.remove('g91-bar__slide--out');
      next.classList.remove('g91-bar__slide--in');
      next.classList.add('g91-bar__slide--visible');
      lock = false;
    }, 500);
  }

  let autoCycle = setInterval(rotate, wait);

  // Restart timer if user interacts with shopify editor
  if (window.Shopify && Shopify.designMode) {
    document.addEventListener('shopify:section:select', () => {
       clearInterval(autoCycle);
       autoCycle = setInterval(rotate, wait);
    });
  }
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Custom Announcement Bar",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (Glow)",
      "default": "#EA580C"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Desktop text size",
      "default": 12
    },
    {
      "type": "range",
      "id": "mobile_text_size",
      "min": 8,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Mobile text size",
      "default": 10
    },
    {
      "type": "header",
      "content": "Message Cycling"
    },
    {
      "type": "range",
      "id": "cycle_speed",
      "min": 2,
      "max": 15,
      "step": 1,
      "unit": "s",
      "label": "Seconds per message",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Message",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_pulse",
          "label": "Show LIVE pulse dot",
          "default": false
        },
        {
          "type": "text",
          "id": "text_prefix",
          "label": "Text before highlight",
          "default": "Join the"
        },
        {
          "type": "text",
          "id": "highlight_text",
          "label": "Highlighted text (Orange)",
          "default": "Riders Club"
        },
        {
          "type": "text",
          "id": "text_suffix",
          "label": "Text after highlight",
          "default": "Today"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Announcement Bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text_prefix": "60,000+",
            "highlight_text": "Followers",
            "text_suffix": "on Instagram",
            "show_pulse": true
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text_prefix": "Free Shipping on Orders Over",
            "highlight_text": "₹2,999"
          }
        }
      ]
    }
  ]
}
{% endschema %}