{% comment %}
  Premium Announcement Bar – Garage91
  Race-inspired, dark-mode aesthetic with vertical slide-up message cycling,
  orange accent glow, pulsing LIVE indicator, and smooth entrance animation.
{% endcomment %}

{%- if section.settings.show_announcement -%}
<div
  class="g91-annc"
  id="g91-annc-{{ section.id }}"
  role="region"
  aria-label="Announcement"
  aria-live="polite"
  style="background:#000000 !important; color:#ffffff !important;"
>
  <div class="g91-annc__inner">
    <div class="g91-annc__slider" aria-atomic="true">

      <div class="g91-annc__msg g91-annc__msg--active">
        <span class="g91-annc__live" aria-hidden="true"></span>
        <span class="g91-annc__accent">60,000+</span>
        <span class="g91-annc__text">Followers on Instagram</span>
        <span class="g91-annc__sep">&mdash;</span>
        <span class="g91-annc__accent">The Fastest Growing Rider Community</span>
      </div>

      <div class="g91-annc__msg">
        <span class="g91-annc__emoji">🚚</span>
        <span class="g91-annc__text">Free Shipping on Orders Over</span>
        <span class="g91-annc__accent">₹2,999</span>
      </div>

      <div class="g91-annc__msg">
        <span class="g91-annc__emoji">🏍</span>
        <span class="g91-annc__text">Join the</span>
        <a href="/pages/riders-club" class="g91-annc__link">Riders Club</a>
        <span class="g91-annc__sep">&mdash;</span>
        <span class="g91-annc__accent">60K Strong</span>
      </div>

    </div>
  </div>
</div>

<style>
  /* ══  RESET: isolate from all theme color schemes  ══ */
  #g91-annc-{{ section.id }},
  #g91-annc-{{ section.id }} *,
  #g91-annc-{{ section.id }} *::before,
  #g91-annc-{{ section.id }} *::after {
    --color-background: 0, 0, 0 !important;
    --color-foreground: 255, 255, 255 !important;
  }

  /* ══  Animations  ══ */
  @keyframes g91SlideDown {
    from { transform: translateY(-100%); opacity: 0; }
    to   { transform: translateY(0);     opacity: 1; }
  }
  @keyframes g91Pulse {
    0%, 100% { opacity: 1;  box-shadow: 0 0 0 0 rgba(234,88,12,.55); }
    50%      { opacity: .65; box-shadow: 0 0 8px 4px rgba(234,88,12,.2); }
  }
  @keyframes g91Glow {
    0%, 100% { text-shadow: 0 0 6px rgba(234,88,12,.4),  0 0 14px rgba(234,88,12,.15); }
    50%      { text-shadow: 0 0 12px rgba(234,88,12,.7), 0 0 28px rgba(234,88,12,.3); }
  }

  /* ══  Bar container  ══ */
  .g91-annc {
    background: #000000 !important;
    color: #ffffff !important;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    font-size: {{ section.settings.text_size }}px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    line-height: 1;
    position: relative;
    z-index: 3;
    overflow: hidden;
    border-bottom: 1px solid rgba(255,255,255,.06);
    animation: g91SlideDown .45s cubic-bezier(.25,.46,.45,.94) both;
  }

  .g91-annc__inner {
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 11px 24px;
    position: relative;
    height: 1.3em;
  }

  /* ══  Slider  ══ */
  .g91-annc__slider {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .g91-annc__msg {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(100%);
    transition: none;
    color: #ffffff !important;
  }

  .g91-annc__msg--active {
    opacity: 1;
    transform: translateY(0);
  }
  .g91-annc__msg--exit {
    opacity: 0;
    transform: translateY(-100%);
    transition: transform .4s cubic-bezier(.4,0,.2,1), opacity .4s cubic-bezier(.4,0,.2,1);
  }
  .g91-annc__msg--enter {
    opacity: 1;
    transform: translateY(0);
    transition: transform .4s cubic-bezier(.4,0,.2,1), opacity .4s cubic-bezier(.4,0,.2,1);
  }

  /* ══  Text pieces  ══ */
  .g91-annc__text {
    color: #ffffff !important;
  }
  .g91-annc__sep {
    color: rgba(255,255,255,.3) !important;
    margin: 0 2px;
  }
  .g91-annc__emoji {
    font-style: normal;
    margin-right: 2px;
  }

  /* ══  Accent (orange glow)  ══ */
  .g91-annc__accent {
    color: #EA580C !important;
    animation: g91Glow 2.5s ease-in-out infinite;
  }

  /* ══  Link  ══ */
  .g91-annc__link {
    color: #EA580C !important;
    text-decoration: underline !important;
    text-underline-offset: 3px;
    text-decoration-color: rgba(234,88,12,.5) !important;
    animation: g91Glow 2.5s ease-in-out infinite;
    background: none !important;
  }
  .g91-annc__link:hover {
    text-decoration-thickness: 2px !important;
    text-decoration-color: #EA580C !important;
  }

  /* ══  LIVE pulse dot  ══ */
  .g91-annc__live {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #EA580C !important;
    margin-right: 8px;
    flex-shrink: 0;
    animation: g91Pulse 1.5s ease-in-out infinite;
  }

  /* ══  Responsive  ══ */
  @media screen and (max-width: 749px) {
    .g91-annc {
      font-size: {{ section.settings.mobile_text_size }}px;
      letter-spacing: .06em;
    }
    .g91-annc__inner {
      padding: 10px 14px;
      height: 1.5em;
    }
    .g91-annc__msg {
      gap: 4px;
      font-size: inherit;
    }
    .g91-annc__sep {
      display: none;
    }
  }

  @media screen and (max-width: 480px) {
    .g91-annc__inner {
      height: auto;
      min-height: 1.4em;
    }
    .g91-annc__msg {
      white-space: normal;
      text-align: center;
      flex-wrap: wrap;
      justify-content: center;
      gap: 3px;
      position: absolute;
      padding: 0 4px;
    }
  }
</style>

<script>
  (function () {
    var bar = document.getElementById('g91-annc-{{ section.id }}');
    if (!bar) return;
    var msgs = bar.querySelectorAll('.g91-annc__msg');
    if (msgs.length < 2) return;

    var idx = 0;
    var len = msgs.length;
    var ms  = {{ section.settings.cycle_speed | default: 5 }} * 1000;
    var busy = false;

    function cycle() {
      if (busy) return;
      busy = true;

      var cur = msgs[idx];
      var nxt = msgs[(idx + 1) % len];

      cur.classList.remove('g91-annc__msg--active', 'g91-annc__msg--enter');
      cur.classList.add('g91-annc__msg--exit');

      nxt.classList.remove('g91-annc__msg--exit');
      nxt.style.transform  = 'translateY(100%)';
      nxt.style.opacity    = '0';
      nxt.style.transition = 'none';

      void nxt.offsetHeight;          /* reflow */

      nxt.style.transition = '';
      nxt.style.transform  = '';
      nxt.style.opacity    = '';
      nxt.classList.add('g91-annc__msg--enter');

      idx = (idx + 1) % len;

      setTimeout(function () {
        cur.classList.remove('g91-annc__msg--exit');
        cur.style.transform  = '';
        cur.style.opacity    = '';
        busy = false;
      }, 450);
    }

    setInterval(cycle, ms);
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#EA580C"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Desktop text size",
      "default": 12
    },
    {
      "type": "range",
      "id": "mobile_text_size",
      "min": 8,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Mobile text size",
      "default": 10
    },
    {
      "type": "header",
      "content": "Message Cycling"
    },
    {
      "type": "range",
      "id": "cycle_speed",
      "min": 3,
      "max": 15,
      "step": 1,
      "unit": "s",
      "label": "Seconds per message",
      "default": 5
    }
  ],
  "presets": [
    {
      "name": "Custom Announcement Bar"
    }
  ]
}
{% endschema %}