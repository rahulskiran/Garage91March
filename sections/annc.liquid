{% comment %}
  Garage91 – Premium Announcement Bar
  Black background, orange accent, vertical slide-up cycling, LIVE pulse, glow effect.
{% endcomment %}

{%- if section.settings.show_announcement -%}
<div id="g91-bar-{{ section.id }}" class="g91-bar" role="region" aria-label="Announcement" aria-live="polite"
  style="background:#000!important;color:#fff!important;">
  <div class="g91-bar__track">
    <div class="g91-bar__slide g91-bar__slide--visible" data-index="0">
      <span class="g91-bar__dot"></span>
      <span class="g91-bar__hi">60,000+</span>
      <span>Followers on Instagram</span>
      <span class="g91-bar__dim">&bull;</span>
      <span class="g91-bar__hi">The Fastest Growing Rider Community</span>
    </div>
    <div class="g91-bar__slide" data-index="1">
      <span>🚚</span>
      <span>Free Shipping on Orders Over</span>
      <span class="g91-bar__hi">₹2,999</span>
    </div>
    <div class="g91-bar__slide" data-index="2">
      <span>🏍</span>
      <span>Join the</span>
      <a href="/pages/riders-club" class="g91-bar__cta">Riders Club</a>
      <span class="g91-bar__dim">&bull;</span>
      <span class="g91-bar__hi">60K Strong</span>
    </div>
  </div>
</div>

<style>
  /* ══════════ Reset theme bleed ══════════ */
  #g91-bar-{{ section.id }},
  #g91-bar-{{ section.id }} * {
    --color-background: 0,0,0 !important;
    --color-foreground: 255,255,255 !important;
    --color-background-rgb: 0,0,0 !important;
    --color-foreground-rgb: 255,255,255 !important;
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* ══════════ Keyframes ══════════ */
  @keyframes g91-entrance {
    from { transform: translateY(-100%); opacity: 0; }
    to   { transform: translateY(0);     opacity: 1; }
  }
  @keyframes g91-pulse {
    0%,100% { transform: scale(1);   opacity: 1; }
    50%     { transform: scale(1.4); opacity: .5; }
  }
  @keyframes g91-glow {
    0%,100% { text-shadow: 0 0 4px rgba(234,88,12,.35); }
    50%     { text-shadow: 0 0 12px rgba(234,88,12,.65), 0 0 24px rgba(234,88,12,.25); }
  }

  /* ══════════ Bar ══════════ */
  .g91-bar {
    all: unset !important;              /* nuke every inherited/theme style */
    display: block !important;
    background: #000000 !important;
    color: #ffffff !important;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif !important;
    font-size: {{ section.settings.text_size }}px !important;
    font-weight: 600 !important;
    letter-spacing: .09em !important;
    text-transform: uppercase !important;
    line-height: 1.4 !important;
    position: relative !important;
    z-index: 3 !important;
    overflow: hidden !important;
    border-bottom: 1px solid rgba(255,255,255,.05) !important;
    animation: g91-entrance .4s ease-out both !important;
    width: 100% !important;
  }

  /* ── Track: holds all slides stacked ── */
  .g91-bar__track {
    position: relative !important;
    width: 100% !important;
    padding: 10px 20px !important;
    min-height: 20px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  /* ── Each slide ── */
  .g91-bar__slide {
    position: absolute !important;
    inset: 0 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 7px !important;
    padding: 10px 20px !important;
    white-space: nowrap !important;
    color: #ffffff !important;
    opacity: 0 !important;
    transform: translateY(110%) !important;
    pointer-events: none !important;
  }

  /* Visible (initial + after enter finishes) */
  .g91-bar__slide--visible {
    opacity: 1 !important;
    transform: translateY(0) !important;
    pointer-events: auto !important;
    position: relative !important;    /* first visible one sets height */
  }

  /* Exit: slide up out */
  .g91-bar__slide--out {
    opacity: 0 !important;
    transform: translateY(-110%) !important;
    transition: transform .4s cubic-bezier(.4,0,.2,1), opacity .4s ease !important;
    pointer-events: none !important;
  }

  /* Enter: slide up in */
  .g91-bar__slide--in {
    opacity: 1 !important;
    transform: translateY(0) !important;
    transition: transform .4s cubic-bezier(.4,0,.2,1), opacity .4s ease !important;
    pointer-events: auto !important;
  }

  /* ── Orange accent with glow ── */
  .g91-bar__hi {
    color: #EA580C !important;
    animation: g91-glow 2.5s ease-in-out infinite !important;
  }

  /* ── Dimmed separator ── */
  .g91-bar__dim {
    color: rgba(255,255,255,.25) !important;
    margin: 0 1px !important;
  }

  /* ── CTA link ── */
  .g91-bar__cta {
    color: #EA580C !important;
    text-decoration: underline !important;
    text-underline-offset: 3px !important;
    text-decoration-color: rgba(234,88,12,.45) !important;
    animation: g91-glow 2.5s ease-in-out infinite !important;
    background: none !important;
    cursor: pointer !important;
  }
  .g91-bar__cta:hover {
    text-decoration-color: #EA580C !important;
  }

  /* ── LIVE pulse dot ── */
  .g91-bar__dot {
    display: inline-block !important;
    width: 6px !important;
    height: 6px !important;
    border-radius: 50% !important;
    background: #EA580C !important;
    flex-shrink: 0 !important;
    margin-right: 4px !important;
    animation: g91-pulse 1.4s ease-in-out infinite !important;
  }

  /* ══════════ Mobile ══════════ */
  @media (max-width: 749px) {
    .g91-bar {
      font-size: {{ section.settings.mobile_text_size }}px !important;
      letter-spacing: .05em !important;
    }
    .g91-bar__track {
      padding: 9px 12px !important;
    }
    .g91-bar__slide {
      gap: 5px !important;
      padding: 9px 12px !important;
      white-space: normal !important;
      flex-wrap: wrap !important;
      text-align: center !important;
    }
    .g91-bar__dim {
      display: none !important;
    }
  }
</style>

<script>
(function(){
  var root = document.getElementById('g91-bar-{{ section.id }}');
  if (!root) return;
  var slides = root.querySelectorAll('.g91-bar__slide');
  if (slides.length < 2) return;

  var i    = 0,
      n    = slides.length,
      wait = {{ section.settings.cycle_speed | default: 5 }} * 1000,
      lock = false;

  function go() {
    if (lock) return;
    lock = true;

    var cur  = slides[i],
        next = slides[(i + 1) % n];

    /* current slides up & out */
    cur.classList.remove('g91-bar__slide--visible','g91-bar__slide--in');
    cur.classList.add('g91-bar__slide--out');

    /* prep next below viewport */
    next.classList.remove('g91-bar__slide--out','g91-bar__slide--visible');
    next.style.cssText = 'transform:translateY(110%)!important;opacity:0!important;transition:none!important;position:absolute!important;';

    void next.offsetHeight; /* reflow */

    next.style.cssText = '';
    next.classList.add('g91-bar__slide--in');

    i = (i + 1) % n;

    setTimeout(function(){
      cur.classList.remove('g91-bar__slide--out');
      cur.style.cssText = '';
      /* Make the new slide set height */
      next.classList.remove('g91-bar__slide--in');
      next.classList.add('g91-bar__slide--visible');
      lock = false;
    }, 450);
  }

  setInterval(go, wait);
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#EA580C"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Desktop text size",
      "default": 12
    },
    {
      "type": "range",
      "id": "mobile_text_size",
      "min": 8,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Mobile text size",
      "default": 10
    },
    {
      "type": "header",
      "content": "Message Cycling"
    },
    {
      "type": "range",
      "id": "cycle_speed",
      "min": 3,
      "max": 15,
      "step": 1,
      "unit": "s",
      "label": "Seconds per message",
      "default": 5
    }
  ],
  "presets": [
    {
      "name": "Custom Announcement Bar"
    }
  ]
}
{% endschema %}