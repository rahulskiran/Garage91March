</div>

<!-- ═══════════════════════════════════════════════════ SCRIPT ═══ -->
<script>
  // Open modal
  function rcOpenModal(rideName) {
    document.getElementById('rc-modal-ride-name').textContent = rideName;
    document.getElementById('rc-ride-input').value = rideName;
    document.getElementById('rc-modal').classList.add('active');
    document.body.style.overflow = 'hidden';
    // Reset to form view
    document.getElementById('rc-form-wrap').style.display = '';
    document.getElementById('rc-success').style.display = 'none';
    document.getElementById('rc-register-form').reset();
    document.getElementById('rc-ride-input').value = rideName;
  }

  // Close modal
  function rcCloseModal() {
    document.getElementById('rc-modal').classList.remove('active');
    document.body.style.overflow = '';
  }

  // Close on backdrop click
  document.getElementById('rc-modal').addEventListener('click', function(e) {
    if (e.target === this) rcCloseModal();
  });

  // Close on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') rcCloseModal();
  });

  // Smooth scroll for hero buttons
  document.querySelectorAll('a[href^="#"]').forEach(function(anchor) {
    anchor.addEventListener('click', function(e) {
      var target = document.querySelector(this.getAttribute('href'));
      if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
    });
  });

  // AJAX Form Submission
  document.getElementById('rc-register-form').addEventListener('submit', function(e) {
    e.preventDefault();
    var btn = document.getElementById('rc-submit-btn');
    btn.disabled = true;
    btn.textContent = 'Submitting…';

    var formData = new FormData(this);

    fetch('/contact#contact_form', {
      method: 'POST',
      headers: { 'X-Requested-With': 'XMLHttpRequest' },
      body: formData
    })
    .then(function(res) {
      // Show success regardless of response body (Shopify redirects, but AJAX catches 200)
      document.getElementById('rc-form-wrap').style.display = 'none';
      document.getElementById('rc-success').style.display = 'block';
    })
    .catch(function() {
      // Fallback: also show success (submission likely went through)
      document.getElementById('rc-form-wrap').style.display = 'none';
      document.getElementById('rc-success').style.display = 'block';
    });
  });
</script>

