{% doc %}
  @prompt
    people view counter , Give me the various options for font settings and options for the transparent option, Give m the setting for the transparent background 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-view-counter-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-view-counter-container-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: {{ block.settings.spacing }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color | color_modify: 'alpha', block.settings.background_opacity | divided_by: 100.0 }};
    border-radius: {{ block.settings.border_radius }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color | color_modify: 'alpha', block.settings.border_opacity | divided_by: 100.0 }};
    {% if block.settings.text_font == 'body' %}
      font-family: var(--font-body-family);
    {% elsif block.settings.text_font == 'heading' %}
      font-family: var(--font-heading-family);
    {% elsif block.settings.text_font == 'subheading' %}
      font-family: var(--font-subheading-family);
    {% elsif block.settings.text_font == 'accent' %}
      font-family: var(--font-accent-family);
    {% endif %}
  }

  .ai-view-counter-icon-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-view-counter-icon-{{ ai_gen_id }} svg {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
  }

  .ai-view-counter-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: {{ block.settings.text_weight }};
    line-height: 1.2;
    white-space: nowrap;
    {% if block.settings.text_transform == 'uppercase' %}
      text-transform: uppercase;
    {% elsif block.settings.text_transform == 'lowercase' %}
      text-transform: lowercase;
    {% elsif block.settings.text_transform == 'capitalize' %}
      text-transform: capitalize;
    {% endif %}
    {% if block.settings.text_style == 'italic' %}
      font-style: italic;
    {% endif %}
  }

  .ai-view-counter-number-{{ ai_gen_id }} {
    font-weight: {{ block.settings.number_weight }};
    color: {{ block.settings.number_color }};
    {% if block.settings.number_font == 'body' %}
      font-family: var(--font-body-family);
    {% elsif block.settings.number_font == 'heading' %}
      font-family: var(--font-heading-family);
    {% elsif block.settings.number_font == 'subheading' %}
      font-family: var(--font-subheading-family);
    {% elsif block.settings.number_font == 'accent' %}
      font-family: var(--font-accent-family);
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-view-counter-container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.8 }}px {{ block.settings.padding_horizontal | times: 0.8 }}px;
    }

    .ai-view-counter-icon-{{ ai_gen_id }} svg {
      width: {{ block.settings.icon_size | times: 0.9 }}px;
      height: {{ block.settings.icon_size | times: 0.9 }}px;
    }

    .ai-view-counter-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<view-counter-{{ ai_gen_id }}
  class="ai-view-counter-{{ ai_gen_id }}"
  data-min="{{ block.settings.min_count }}"
  data-max="{{ block.settings.max_count }}"
  data-update-interval="{{ block.settings.update_interval }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-view-counter-container-{{ ai_gen_id }}">
    {% if block.settings.show_icon %}
      <div class="ai-view-counter-icon-{{ ai_gen_id }}">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
          <circle cx="12" cy="12" r="3"></circle>
        </svg>
      </div>
    {% endif %}
    <div class="ai-view-counter-text-{{ ai_gen_id }}">
      <span class="ai-view-counter-number-{{ ai_gen_id }}">0</span> {{ block.settings.counter_text }}
    </div>
  </div>
</view-counter-{{ ai_gen_id }}>

<script>
  (function() {
    class ViewCounter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.minCount = parseInt(this.dataset.min) || 10;
        this.maxCount = parseInt(this.dataset.max) || 50;
        this.updateInterval = parseInt(this.dataset.updateInterval) || 5000;
        this.currentCount = 0;
        this.numberElement = null;
      }

      connectedCallback() {
        this.numberElement = this.querySelector('.ai-view-counter-number-{{ ai_gen_id }}');
        this.initializeCounter();
        this.startUpdating();
      }

      initializeCounter() {
        this.currentCount = this.getRandomCount();
        this.updateDisplay();
      }

      getRandomCount() {
        return Math.floor(Math.random() * (this.maxCount - this.minCount + 1)) + this.minCount;
      }

      updateDisplay() {
        if (this.numberElement) {
          this.numberElement.textContent = this.currentCount;
        }
      }

      startUpdating() {
        setInterval(() => {
          const change = Math.random() < 0.5 ? -1 : 1;
          const newCount = this.currentCount + change;
          
          if (newCount >= this.minCount && newCount <= this.maxCount) {
            this.currentCount = newCount;
          } else if (newCount < this.minCount) {
            this.currentCount = this.minCount + 1;
          } else {
            this.currentCount = this.maxCount - 1;
          }
          
          this.updateDisplay();
        }, this.updateInterval);
      }
    }

    customElements.define('view-counter-{{ ai_gen_id }}', ViewCounter{{ ai_gen_id }});
  })();
</script>

