{% doc %}
  @prompt
    add a footer copyright block including the year and store name and give me the colour options for it and add the Built by the Texnoid.com and when they clicks the texnoid.com it has to redirect to the instagram URL
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-footer-copyright-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-footer-copyright__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing }}px;
    align-items: center;
  }

  .ai-footer-copyright__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    margin: 0;
  }

  .ai-footer-copyright__built-by-{{ ai_gen_id }} {
    color: {{ block.settings.built_by_text_color }};
    font-size: {{ block.settings.built_by_font_size }}px;
    margin: 0;
  }

  .ai-footer-copyright__link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .ai-footer-copyright__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
    text-decoration: underline;
  }

  @media screen and (min-width: 750px) {
    .ai-footer-copyright__content-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.desktop_layout }};
      justify-content: center;
    }
  }
{% endstyle %}

<div class="ai-footer-copyright-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-footer-copyright__content-{{ ai_gen_id }}">
    <p class="ai-footer-copyright__text-{{ ai_gen_id }}">
      © {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ block.settings.copyright_text }}
    </p>
    <p class="ai-footer-copyright__built-by-{{ ai_gen_id }}">
      Built by <a href="{{ block.settings.instagram_url }}" class="ai-footer-copyright__link-{{ ai_gen_id }}" target="_blank" rel="noopener noreferrer">Texnoid.com</a>
    </p>
  </div>
</div>

{% schema %}
{
  "name": "Footer copyright",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "All rights reserved."
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "Desktop layout",
      "options": [
        {
          "value": "column",
          "label": "Stacked"
        },
        {
          "value": "row",
          "label": "Side by side"
        }
      ],
      "default": "row"
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Spacing between elements",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 20
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Copyright text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "built_by_text_color",
      "label": "Built by text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link",
      "default": "#ff0000"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Copyright font size",
      "default": 12
    },
    {
      "type": "range",
      "id": "built_by_font_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Built by font size",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Footer copyright"
    }
  ]
}
{% endschema %}